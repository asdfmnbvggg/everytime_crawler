#로그인은 에브리타임에서 수동으로 해주기. 수동으로 한 후 enter 쳐서 이후 진행.

# 게시판 번호
# 예: https://everytime.kr/123456/p/1 이면 BOARD_NUMBER=123456
BOARD_NUMBER=게시판번호입력

# 검색 키워드
# 여러 개는 쉼표로 구분
# 예: KEY_WORD=자취,원룸,기숙사
KEY_WORD=키워드

# 크롤링 페이지 범위
START_PAGE=1
END_PAGE=10

# 요청 간 대기 시간
PAGE_DELAY=1.5
POST_DELAY=0.7

# true로 바꾸면 브라우저 창 없이 실행
HEADLESS=false
